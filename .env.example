# EduNexus — copy to .env.local and adjust as needed

# Application
VITE_APP_NAME=EduNexus

# API (email server runs on port 3000; Vite proxies /api → localhost:3000)
VITE_API_URL=/api/v1
VITE_USE_MOCK_API=true

# Development
VITE_ENABLE_DEVTOOLS=true

# Mobile QR / external apply link (use your PC LAN IP — ipconfig on Windows)
# Example: http://192.168.0.4:5173
VITE_PUBLIC_APP_URL=http://192.168.0.4:5173

# ── Email server (server/index.mjs) — add to .env.local ──
# Without SMTP, Ethereal test mail is used (emails work with a preview link in the UI).
# For real delivery (Gmail example):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="Admissions Team" <your@gmail.com>
# EMAIL_SERVER_PORT=3000
